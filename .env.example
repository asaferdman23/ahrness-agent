# ── Model provider ────────────────────────────────────────────────────────────
# Uses Amazon Bedrock by default.
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# OR: Use Anthropic directly
# ANTHROPIC_API_KEY=

# ── Meta App (for client OAuth) ───────────────────────────────────────────────
# Create a Meta Developer App at developers.facebook.com
# Add the "Marketing API" product, then find these under Settings → Basic
META_APP_ID=
META_APP_SECRET=

# ── OAuth callback server ─────────────────────────────────────────────────────
# Where Meta redirects clients after they authorize.
# For local dev: use ngrok → `ngrok http 3456` → paste the https URL here
# For production: your server's public domain
CALLBACK_BASE_URL=https://your-domain.com
CALLBACK_PORT=3456

# ── Meta Ads write access ─────────────────────────────────────────────────────
# false = read-only (safe default). true = allows creating/editing campaigns.
META_ADS_ENABLE_WRITE_TOOLS=false

# ── Higgsfield MCP ────────────────────────────────────────────────────────────
# One shared server-owned Higgsfield account. After deployment, visit:
#   https://your-domain.com/auth/higgsfield/start?key=<HIGGSFIELD_SETUP_SECRET>
# Clients do not authenticate with Higgsfield themselves.
HIGGSFIELD_MCP_URL=https://mcp.higgsfield.ai/mcp
HIGGSFIELD_SETUP_SECRET=replace-with-a-long-random-secret
MEDIA_SIGNING_SECRET=replace-with-another-long-random-secret

# Optional alternative for deployments that already manage a valid OAuth token.
# HIGGSFIELD_MCP_ACCESS_TOKEN=

# Simple daily safety limit per WhatsApp client. Set 0 to disable generation.
HIGGSFIELD_DAILY_GENERATION_LIMIT=10
HIGGSFIELD_JOB_TIMEOUT_MS=600000

# ── WhatsApp auth ─────────────────────────────────────────────────────────────
# Phone number for pairing-code auth (digits only, country code + number, no +)
# Leave blank to use QR code
WHATSAPP_PHONE_NUMBER=

# ── Agent personality ─────────────────────────────────────────────────────────
AGENT_NAME=Ahrness

# ── Per-client execution sandbox ──────────────────────────────────────────────
# Sandboxes run on this server; WhatsApp clients do not install anything.
# Build the image before starting the agent:
#   docker build -f Dockerfile.sandbox -t ahrness-sandbox:latest .
AGENT_SANDBOX_ENABLED=true
AGENT_SANDBOX_IMAGE=ahrness-sandbox:latest
AGENT_WORKSPACES_DIR=./store/workspaces

# "none" is the safe default. Meta Ads and Higgsfield tools still run from the
# host agent process and do not need container network access.
AGENT_SANDBOX_NETWORK=none
AGENT_SANDBOX_MEMORY=512m
AGENT_SANDBOX_CPUS=1
AGENT_SANDBOX_PIDS_LIMIT=128

# Optional numeric uid:gid. By default the service uid:gid is used; if the
# service runs as root, the sandbox uses 65534:65534 and never container root.
# AGENT_SANDBOX_USER=1000:1000

# Maximum size of one file delivered through WhatsApp (25 MiB by default).
AGENT_MAX_OUTPUT_BYTES=26214400
AGENT_MAX_INPUT_BYTES=26214400
