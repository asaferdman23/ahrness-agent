# ── Model provider ────────────────────────────────────────────────────────────
# Direct Anthropic API (default for this project).
ANTHROPIC_API_KEY=
# Must be a valid Anthropic API model id (NOT a Bedrock id).
AGENT_MODEL=claude-opus-4-8
# Max output tokens per response (pinned to avoid SDK default drift).
AGENT_MAX_TOKENS=16384

# Alternative: Amazon Bedrock. Leave ANTHROPIC_API_KEY blank and set these, then
# pass a Bedrock-style AGENT_MODEL (e.g. global.anthropic.claude-...).
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Google Auth (better-auth — dashboard & onboarding sign-in) ───────────────
# Create OAuth credentials at console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 32+ random chars: openssl rand -hex 32
BETTER_AUTH_SECRET=

# ── Meta App (for client OAuth) ───────────────────────────────────────────────
# Create a Meta Developer App at developers.facebook.com
# Add the "Marketing API" product, then find these under Settings → Basic
META_APP_ID=
META_APP_SECRET=

# ── OAuth callback server ─────────────────────────────────────────────────────
# Where Meta redirects clients after they authorize.
# For local dev: use ngrok → `ngrok http 3456` → paste the https URL here
# For production: your server's public domain
CALLBACK_BASE_URL=https://your-domain.com
CALLBACK_PORT=3456

# ── Meta Ads write access ─────────────────────────────────────────────────────
# false = read-only (safe default). true = allows creating/editing campaigns.
META_ADS_ENABLE_WRITE_TOOLS=false

# ── Higgsfield MCP ────────────────────────────────────────────────────────────
# One shared server-owned Higgsfield account. After deployment, visit:
#   https://your-domain.com/auth/higgsfield/start?key=<HIGGSFIELD_SETUP_SECRET>
# Clients do not authenticate with Higgsfield themselves.
HIGGSFIELD_MCP_URL=https://mcp.higgsfield.ai/mcp
HIGGSFIELD_SETUP_SECRET=replace-with-a-long-random-secret
MEDIA_SIGNING_SECRET=replace-with-another-long-random-secret

# Optional alternative for deployments that already manage a valid OAuth token.
# HIGGSFIELD_MCP_ACCESS_TOKEN=

# Simple daily safety limit per WhatsApp client. Set 0 to disable generation.
HIGGSFIELD_DAILY_GENERATION_LIMIT=10
HIGGSFIELD_JOB_TIMEOUT_MS=600000

# ── WhatsApp ──────────────────────────────────────────────────────────────────
# Provider: twilio (WhatsApp Business API), baileys (dev), or dual/all to show both
# choices in onboarding and route scheduled messages by each client's preference.
WHATSAPP_PROVIDER=baileys
# Default inbound policy is fail-closed unless sender is linked to a tenant or allowlisted.
# Set true only for local demos where unknown WhatsApp senders should get the guest agent.
AGENT_ALLOW_UNLINKED_SENDERS=false

# Twilio — copy from producegerx_backend .env (Console → Account Info)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# With or without whatsapp: prefix.
TWILIO_WHATSAPP_NUMBER=whatsapp:+15558136169
# Optional — if set, used as sender instead of TWILIO_WHATSAPP_NUMBER
TWILIO_MESSAGING_SERVICE_SID=

# Baileys only — phone number for pairing-code auth (digits only, no +)
# Leave blank to use QR code
WHATSAPP_PHONE_NUMBER=
# Baileys safety mode: the agent lives only in one configured WhatsApp group and
# runs only when addressed with the trigger, e.g. "@bizzclaw hi".
BAILEYS_GROUP_ONLY=true
BAILEYS_REQUIRE_TRIGGER=true
BAILEYS_AGENT_TRIGGERS=@bizzclaw
# Required for group mode. When missing, the server logs the group JID after a
# triggered group message so you can copy it here.
BAILEYS_ALLOWED_GROUP_JIDS=
# Optional: restrict who inside the allowed group can trigger the agent.
# Example: 15551234567@s.whatsapp.net
BAILEYS_ALLOWED_GROUP_PARTICIPANTS=

# ── Telegram (optional additional channel) ────────────────────────────────────
# Shared platform bot: create one bot via @BotFather, set its token here, and a
# "Connect Telegram" button appears on each client's dashboard (t.me deep link,
# signed with MEDIA_SIGNING_SECRET below). Leave blank to disable.
TELEGRAM_BOT_TOKEN=

# BYO per-client bots are also supported without any env var — connected out
# of band and stored encrypted per-client (see ARCHITECTURE.md → Messaging Channels):
#   npm run connect:telegram -- <clientId> <botToken>

# ── Slack (optional additional channel) ───────────────────────────────────────
# Multi-tenant: each client installs your Slack App into their own workspace via
# a "Connect Slack" button on their dashboard (OAuth v2). Create the app at
# api.slack.com/apps — Redirect URL: <CALLBACK_BASE_URL>/auth/slack/callback,
# Event Subscriptions Request URL: <CALLBACK_BASE_URL>/webhooks/slack/events.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Verifies inbound Events API requests are really from Slack (Basic Information page).
SLACK_SIGNING_SECRET=

# ── Agent personality ─────────────────────────────────────────────────────────
AGENT_NAME=BizzClaw

# Timezone used to evaluate scheduled automations (IANA name). Defaults to UTC.
AGENT_TIMEZONE=UTC

# ── Per-client execution sandbox ──────────────────────────────────────────────
# Sandboxes run on this server; WhatsApp clients do not install anything.
# Build the image before starting the agent:
#   docker build -f Dockerfile.sandbox -t ahrness-sandbox:latest .
AGENT_SANDBOX_ENABLED=true
AGENT_SANDBOX_IMAGE=ahrness-sandbox:latest
AGENT_WORKSPACES_DIR=./store/workspaces

# "none" is the safe default. Meta Ads and Higgsfield tools still run from the
# host agent process and do not need container network access.
AGENT_SANDBOX_NETWORK=none
AGENT_SANDBOX_MEMORY=512m
AGENT_SANDBOX_CPUS=1
AGENT_SANDBOX_PIDS_LIMIT=128

# Optional numeric uid:gid. By default the service uid:gid is used; if the
# service runs as root, the sandbox uses 65534:65534 and never container root.
# AGENT_SANDBOX_USER=1000:1000

# Maximum size of one file delivered through WhatsApp (25 MiB by default).
AGENT_MAX_OUTPUT_BYTES=26214400
AGENT_MAX_INPUT_BYTES=26214400

# ── Secret vault (REQUIRED) ────────────────────────────────────────────────────
# Master key that encrypts every client's OAuth tokens at rest (AES-256-GCM).
# Must be at least 32 characters. Generate one with:  openssl rand -hex 32
# Losing/changing it makes existing stored tokens unreadable (clients re-connect).
AGENT_MASTER_KEY=
# Where per-client state lives (clients/, vault.salt). Defaults to ./store
# AGENT_STORE_DIR=./store

# ── Who may talk to the agent ─────────────────────────────────────────────────
# Comma-separated allowed senders (phone numbers or JIDs). If empty, normal
# inbound messages are allowed only for WhatsApp senders linked to a tenant.
# AGENT_ALLOWED_SENDERS=+15551234567,+447700900000

# Allow http:// callback on a non-local host (NOT recommended — OAuth in cleartext)
# ALLOW_INSECURE_CALLBACK=false

# ── Autonomous web access (optional) ──────────────────────────────────────────
# Brokered search: key stays host-side and never enters the sandbox or the model.
# WEB_SEARCH_API_KEY=

# Let sandbox code (curl/scrape) reach the web through a filtering proxy. When
# true, the sandbox has NO internet of its own — its only route out is the proxy,
# which allows ONLY the domains below and blocks private/loopback addresses.
# Requires Docker. Leave false to keep the sandbox fully network-isolated.
AGENT_SANDBOX_EGRESS=false
# Comma-separated allowlist; supports *.example.com and * (all). Empty = deny all.
AGENT_WEB_ALLOWLIST=
# Per-source CONNECTs per minute through the proxy (0 = unlimited).
EGRESS_MAX_PER_MINUTE=120
# Repo path mounted read-only into the proxy container (defaults to "." / cwd).
# AGENT_REPO_DIR=.
